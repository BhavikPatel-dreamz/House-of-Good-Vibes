{
  "include": ["env.d.ts", "**/*.ts", "**/*.tsx", ".react-router/types/**/*"],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "removeComments": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "gutenberg-block-kit/actions": ["app/lib/gutenberg-actions.ts"],
      "gutenberg-block-kit/actions-kit": [
        "node_modules/gutenberg-block-kit/dist/actions.mjs"
      ]
    },
    "types": [
      "@react-router/node",
      "vite/client",
      "@shopify/polaris-types",
      "@shopify/app-bridge-types"
    ],
    "rootDirs": [".", "./.react-router/types"]
  }
}
